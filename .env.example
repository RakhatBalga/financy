# --- Telegram ---
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here

# Webhook (leave WEBHOOK_URL empty to run in long-polling mode locally)
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=change-me-random-string
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# --- Database ---
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance
POSTGRES_DB=finance
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Gemini ---
# Put your REAL key only here in .env (this file's copy), never in git.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-pro-preview

# --- App ---
DEFAULT_CURRENCY=KZT
LOG_LEVEL=INFO
TZ=Asia/Almaty
